# Required for docker-compose
SECRET_KEY=change-me-min-32-chars-please-please-please
ADMIN_API_KEY=change-me-admin-key

# Optional
ACCESS_TOKEN_EXPIRE_MINUTES=60

# If frontend is on a different host than backend (e.g. behind a reverse proxy)
PUBLIC_API_URL=http://localhost:8000

# Default uses SQLite. For Postgres:
# DATABASE_URL=postgresql://finsight:secret@db:5432/finsight
