# ==================== APP CONFIGURATION ====================
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION CHECKLIST — the app REFUSES to boot with ENVIRONMENT=production │
# │ until these are changed from their placeholder values:                    │
# │   • SECRET_KEY     — generate with:  openssl rand -hex 32                  │
# │   • ADMIN_PASSWORD — a strong unique password                             │
# │   • ADMIN_API_KEY  — a random token (openssl rand -hex 24)                 │
# │ Also set CORS_ORIGINS to your real domain(s); never "*" with credentials. │
# └─────────────────────────────────────────────────────────────────────────┘
APP_NAME=FinSight
APP_VERSION=1.0.0
DEBUG=True
# development = insecure placeholders only warn; production = they hard-fail.
ENVIRONMENT=development

# ==================== DATABASE ====================
# SQLite (default — no setup required):
DATABASE_URL=sqlite:///./data/finsight.db
# PostgreSQL (production — install psycopg2-binary; already in requirements.txt):
# DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight
# Docker PostgreSQL (from docker-compose postgres service):
# DATABASE_URL=postgresql://finsight:finsight@postgres:5432/finsight

# ==================== JWT & SECURITY ====================
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== BCRYPT ====================
BCRYPT_LOG_ROUNDS=12

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# ==================== EMAIL CONFIGURATION ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@finsight.io
SENDER_NAME=FinSight Team

# ==================== API KEYS ====================
# Yahoo Finance API (free, no key needed)
YFINANCE_API_KEY=

# Binance API (free with rate limits)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# NewsAPI (get free key from https://newsapi.org)
NEWSAPI_KEY=your-newsapi-key

# HuggingFace (for FinBERT sentiment)
HUGGINGFACE_API_KEY=your-huggingface-key

# ==================== MACHINE LEARNING ====================
MODEL_PATH=./models/trained/
DATA_PATH=./data/
BATCH_SIZE=32
EPOCHS=50
LSTM_UNITS=128
LOOKBACK_WINDOW=60
TRAIN_TEST_SPLIT=0.8

# ==================== CACHE ====================
CACHE_ENABLED=true
CACHE_TTL=300  # 5 minutes in seconds
REDIS_URL=redis://localhost:6379/0  # Optional, uses in-memory if not set

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==================== EXTERNAL SERVICES ====================
SENTRY_DSN=  # Optional: Sentry error tracking

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ==================== DATA REFRESH ====================
MARKET_DATA_REFRESH_INTERVAL=300  # 5 minutes
NEWS_REFRESH_INTERVAL=3600  # 1 hour
MODEL_RETRAIN_INTERVAL=604800  # 7 days

# ==================== ADMIN ====================
ADMIN_EMAIL=admin@finsight.io
ADMIN_PASSWORD=change-me-in-production
ADMIN_API_KEY=admin-api-key-change-this

# ==================== TIMEZONE ====================
TIMEZONE=UTC
