{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/", "destination": "/landing.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!landing\\.html$).*)", "destination": "/index.html" }
  ]
}
