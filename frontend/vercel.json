{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/landing.html", "destination": "/" }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/dashboard(.*)", "destination": "/app.html" },
    { "source": "/stocks(.*)", "destination": "/app.html" },
    { "source": "/predictions(.*)", "destination": "/app.html" },
    { "source": "/portfolio(.*)", "destination": "/app.html" },
    { "source": "/news(.*)", "destination": "/app.html" },
    { "source": "/admin(.*)", "destination": "/app.html" },
    { "source": "/backtesting(.*)", "destination": "/app.html" }
  ]
}
