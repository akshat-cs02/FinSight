    "gsap": "^3.15.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.294.0",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "tailwindcss": "^3.3.0",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
