  "description": "FinSight - AI-Based Stock Market Analysis & Prediction Platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/app.html');fs.copyFileSync('public/landing.html','dist/index.html');console.log('Swapped: landing.html → index.html, React → app.html')\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
