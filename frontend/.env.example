# Backend API
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=FinSight
VITE_APP_VERSION=1.0.0
VITE_DEBUG=true

# Feature Flags
VITE_ENABLE_PREDICTIONS=true
VITE_ENABLE_PORTFOLIO=true
VITE_ENABLE_SENTIMENT=true
VITE_ENABLE_ADMIN=true
VITE_ENABLE_REPORTS=true

# Chart Configuration
VITE_CHART_THEME=dark
VITE_CANDLESTICK_HEIGHT=400

# Polling Intervals (ms)
VITE_MARKET_DATA_INTERVAL=5000
VITE_NEWS_INTERVAL=30000
